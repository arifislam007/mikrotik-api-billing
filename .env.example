# ============================================================
# Root — Vite frontend build (copy to .env in project root)
# ============================================================
# For production builds served by nginx on the same host,
# leave this as /api (relative path).
# For a different host/port, set to http://YOUR_HOST/api
VITE_API_URL=/api

# ============================================================
# backend/.env — Node.js API server
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mikrotik_billing
DB_USER=postgres
DB_PASSWORD=change_me
PORT=3000

# ============================================================
# gateway/.env — Express proxy / API gateway
# ============================================================
BACKEND_URL=http://localhost:3000
GATEWAY_PORT=8080
