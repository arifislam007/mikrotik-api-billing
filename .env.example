# ============================================================
# Root — Vite frontend build (copy to .env in project root)
# ============================================================
VITE_API_URL=/api

# ============================================================
# backend/.env — Node.js API server
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mikrotik_billing
DB_USER=billing
DB_PASSWORD=change_me
PORT=3000
JWT_SECRET=change_me_to_a_long_random_string

# ============================================================
# gateway/.env — Express proxy / API gateway
# ============================================================
BACKEND_URL=http://localhost:3000
GATEWAY_PORT=8080
